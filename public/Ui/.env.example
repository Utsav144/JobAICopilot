NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-test-key
STRIPE_ACCOUNT_ID=acct_your_account_id_here

# Use Stripe test keys while testing. Do not use real card details in live mode.
STRIPE_SECRET_KEY=your-stripe-secret-test-key

# Optional: use real Stripe Price IDs from Products > Prices.
# If omitted, the app creates monthly subscription line items with inline price_data.
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# Email OTP login. Server-side only; do not expose this with NEXT_PUBLIC_.
BREVO_API_KEY=your-brevo-api-key
AUTH_EMAIL_FROM=verified-sender@yourdomain.com
AUTH_EMAIL_FROM_NAME=JobPilot AI
AUTH_OTP_SECRET=replace-with-a-long-random-secret
