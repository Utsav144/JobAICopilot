NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/job_agent
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
SCHEDULER_ENABLED=false
DAILY_CRON=0 9 * * *
DAILY_SUBMITTED_GOAL=20
DAILY_GOAL_RETRY_MINUTES=10
SCHEDULER_RUN_ON_START=false
MAX_APPLICATIONS_PER_DAY=50
MIN_ATS_SCORE=75
USER_TIMEZONE=Asia/Kolkata
PLAYWRIGHT_HEADLESS=false
HUMAN_APPROVAL_REQUIRED=true
ENABLE_LIVE_JOB_SEARCH=false
NAUKRI_BROWSER_CHANNEL=
RESUME_SOURCE_PATH=./data/resumes/Utsav_Dwivedi_Master_Resume.txt

AUTO_ASSIST_APPLICATIONS=false
SEND_DAILY_EMAIL_REPORT=false
EMAIL_REPORT_MIN_SUBMITTED=20
REPORT_EMAIL_TO=your-report-email@example.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-smtp-login
SMTP_PASS=your-brevo-smtp-key
SMTP_FROM=verified-sender@yourdomain.com

REQUIRE_VERIFIED_MNC=true

APPLICANT_NAME=Utsav Dwivedi
APPLICANT_EMAIL=
APPLICANT_PHONE=
APPLICANT_LOCATION=Noida, India
APPLICANT_LINKEDIN=
APPLICANT_GITHUB=
APPLICANT_PORTFOLIO=

EMAIL_PROVIDER=brevo-api
BREVO_API_KEY=your-brevo-api-key
BREVO_ALLOWED_OUTBOUND_IPS=
BREVO_CHECK_OUTBOUND_IP=true
BREVO_DIRECT_IP_FALLBACK=false
